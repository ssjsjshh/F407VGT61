{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Debug (STM32F407VGTx)",
            "type": "cortex-debug",
            "request": "launch",
            "servertype": "openocd",
            "cwd": "${workspaceFolder}",
            "executable": "${workspaceFolder}/build/Debug/F407VGT6.elf",
            "device": "STM32F407VGTx",
            "runToEntryPoint": "main",
            "showDevDebugOutput": "none",
            "armToolchainPath": "C:/Program Files/Arm/GNU Toolchain mingw-w64-x86_64-arm-none-eabi/bin",
            "gdbPath": "C:/Program Files/Arm/GNU Toolchain mingw-w64-x86_64-arm-none-eabi/bin/arm-none-eabi-gdb.exe",
            "serverpath": "openocd",
            "interface": "swd",
            "configFiles": [
                "interface/cmsis-dap.cfg",
                "target/stm32f4x.cfg"
            ],
            "openOCDLaunchCommands": [
                "transport select swd",
                "adapter speed 4000"
            ]
        }
    ]
}